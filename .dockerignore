# ============================================
# .dockerignore
# Docker 이미지 빌드 시 제외할 파일들
# (이미지 크기 최소화 + 빌드 속도 향상)
# ============================================

# ============================================
# Git 관련 (이미지에 불필요)
# ============================================
.git/
.gitignore
.gitattributes
.github/

# ============================================
# 문서 (프로덕션에 불필요)
# ============================================
*.md
docs/
LICENSE
CHANGELOG.md

# 예외: requirements.txt는 필요
!requirements.txt

# ============================================
# 개발 도구 설정
# ============================================
.vscode/
.idea/
*.code-workspace
.editorconfig

# ============================================
# 환경 변수 파일 (보안)
# ============================================
.env
.env.*
!.env.example

# ============================================
# Python 캐시 (빌드 시 재생성)
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.mypy_cache/
.pytest_cache/
.coverage

# 가상 환경 (Docker 내부에서 새로 생성)
venv/
env/
ENV/
.venv

# ============================================
# 테스트 파일 (프로덕션 불필요)
# ============================================
tests/
test_*.py
*_test.py
.pytest_cache/
.tox/
htmlcov/
coverage.xml

# ============================================
# 데이터 파일 (외부 볼륨 마운트 사용)
# ============================================
# 법률 문서 데이터는 Docker 볼륨으로 마운트
data/
*.jsonl
*.csv
*.db
*.sqlite

# 업로드/임시 파일
uploads/
temp/
tmp/

# Qdrant 데이터 (볼륨 마운트)
qdrant_storage/
qdrant_data/

# ============================================
# 로그 파일
# ============================================
logs/
*.log

# ============================================
# Docker 관련 (중복 방지)
# ============================================
Dockerfile*
docker-compose*.yml
.dockerignore

# ============================================
# CI/CD 설정 (이미지에 불필요)
# ============================================
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile

# ============================================
# Node.js (프론트엔드)
# ============================================
node_modules/
npm-debug.log
yarn-error.log

# ============================================
# OS 관련 파일
# ============================================
.DS_Store
Thumbs.db
Desktop.ini

# ============================================
# 빌드 결과물 (재빌드)
# ============================================
build/
dist/
*.egg-info/

# ============================================
# IDE 관련
# ============================================
.ipynb_checkpoints/
*.ipynb
*.swp
*.swo
*~

# ============================================
# 보안 관련
# ============================================
*.key
*.pem
*.p12
secrets/

# ============================================
# Makefile (프로덕션 불필요)
# ============================================
Makefile
