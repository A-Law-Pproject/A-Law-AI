{
  "title": "A-LAW RAG + LLMOps 모니터링",
  "uid": "alaw-rag-dashboard",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "RPS (초당 요청 수)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[30s])) by (handler)",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 2,
      "title": "에러율 (HTTP 5xx)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[30s])) / sum(rate(http_requests_total[30s])) * 100",
          "legendFormat": "에러율 (%)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 3,
      "title": "P95 응답시간 (엔드포인트별)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (handler, le)) * 1000",
          "legendFormat": "P95 {{handler}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[1m])) by (handler, le)) * 1000",
          "legendFormat": "P50 {{handler}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2000 },
              { "color": "red", "value": 3000 }
            ]
          },
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 4,
      "title": "KURE 임베딩 지연 (CPU 병목 핵심 지표)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(rag_embedding_latency_seconds_bucket[1m])) * 1000",
          "legendFormat": "P95 임베딩 (ms)",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(rag_embedding_latency_seconds_bucket[1m])) * 1000",
          "legendFormat": "P50 임베딩 (ms)",
          "refId": "B"
        },
        {
          "expr": "rate(rag_embedding_latency_seconds_sum[1m]) / rate(rag_embedding_latency_seconds_count[1m]) * 1000",
          "legendFormat": "평균 임베딩 (ms)",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          },
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 5,
      "title": "LLM 응답 대기 (OpenAI)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(rag_llm_latency_seconds_bucket[1m])) * 1000",
          "legendFormat": "P95 LLM (ms)",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(rag_llm_latency_seconds_bucket[1m])) * 1000",
          "legendFormat": "P50 LLM (ms)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 6,
      "title": "CPU 사용률",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[30s]) * 100",
          "legendFormat": "FastAPI CPU (%)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        }
      }
    },
    {
      "id": 7,
      "title": "메모리 사용량 (RSS)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "RSS (MB)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 8,
      "title": "현재 P95 응답시간",
      "type": "stat",
      "gridPos": { "x": 0, "y": 24, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[2m])) by (le)) * 1000",
          "legendFormat": "P95 (ms)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2000 },
              { "color": "red", "value": 3000 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 9,
      "title": "현재 KURE P95",
      "type": "stat",
      "gridPos": { "x": 6, "y": 24, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(rag_embedding_latency_seconds_bucket[2m])) * 1000",
          "legendFormat": "Embedding P95 (ms)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 10,
      "title": "현재 에러율",
      "type": "stat",
      "gridPos": { "x": 12, "y": 24, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[2m])) / sum(rate(http_requests_total[2m])) * 100",
          "legendFormat": "Error Rate (%)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 11,
      "title": "현재 RPS",
      "type": "stat",
      "gridPos": { "x": 18, "y": 24, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[30s]))",
          "legendFormat": "RPS",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 12,
      "title": "법령 인용률",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "100 * sum(rate(rag_legal_citation_total{has_citation=\"true\"}[5m])) by (endpoint) / clamp_min(sum(rate(rag_legal_citation_total[5m])) by (endpoint), 0.001)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "green", "value": 80 }
            ]
          },
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 13,
      "title": "회피 응답률 / 빈 컨텍스트율",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 28, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "100 * sum(rate(rag_refusal_response_total{is_refusal=\"true\"}[5m])) by (endpoint) / clamp_min(sum(rate(rag_refusal_response_total[5m])) by (endpoint), 0.001)",
          "legendFormat": "회피 {{endpoint}}",
          "refId": "A"
        },
        {
          "expr": "100 * sum(rate(rag_empty_context_total{is_empty_context=\"true\"}[5m])) by (endpoint) / clamp_min(sum(rate(rag_empty_context_total[5m])) by (endpoint), 0.001)",
          "legendFormat": "빈컨텍스트 {{endpoint}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 20 }
            ]
          },
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 14,
      "title": "평균 Reranker Score",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 28, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(rag_reranker_score_sum[5m])) by (endpoint) / clamp_min(sum(rate(rag_reranker_score_count[5m])) by (endpoint), 0.001)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": -3 },
              { "color": "green", "value": -1 }
            ]
          },
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 15,
      "title": "Retrieval Hit Rate",
      "type": "stat",
      "gridPos": { "x": 0, "y": 36, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "100 * sum(rate(rag_retrieval_hit_total{has_documents=\"true\"}[5m])) / clamp_min(sum(rate(rag_retrieval_hit_total[5m])), 0.001)",
          "legendFormat": "Hit Rate (%)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 90 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    }
  ]
}
